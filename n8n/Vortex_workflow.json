      "parameters": {
        "jsCode": "const hours = [\"8 AM\", \"9 AM\", \"10 AM\", \"11 AM\", \"12 PM\", \"1 PM\", \"2 PM\", \"3 PM\", \"4 PM\", \"5 PM\", \"6 PM\"];\nlet teamTotal = 0;\nlet lastHour = \"\";\nlet agentsProcessed = [];\n\nconst inputItems = $input.all();\n\n// Calculate totals and real-time average\ninputItems.forEach(item => {\n  let row = item.json;\n  let agentSum = 0;\n  let agentName = row[\"Agent\"] || row[\"Agente\"] || row[\"agente\"] || \"Unknown\";\n\n  hours.forEach(h => {\n    let val = parseInt(row[h]);\n    if (!isNaN(val)) {\n      agentSum += val;\n      lastHour = h;\n    }\n  });\n\n  if (agentSum > 0) {\n    teamTotal += agentSum;\n    agentsProcessed.push({ name: agentName, tickets: agentSum });\n  }\n});\n\nconst teamAverage = agentsProcessed.length > 0 ? teamTotal / agentsProcessed.length : 0;\n\n\n// --- SYNCHRONIZED SLA LOGIC (Power BI Equivalent) ---\nconst hourMapping = {\n  \"8 AM\": 1, \"9 AM\": 2, \"10 AM\": 3, \"11 AM\": 4, \n  \"12 PM\": 5, \"1 PM\": 6, \"2 PM\": 7, \"3 PM\": 8, \n  \"4 PM\": 9, \"5 PM\": 10, \"6 PM\": 11\n};\n\nconst hoursSinceStart = hourMapping[lastHour] || 1;\nconst expectedGoal = hoursSinceStart * 5.6;\nconst slaResult = (teamAverage / expectedGoal).toFixed(2);\n\n// Shift logic\nlet outgoingShift = \"\";\nif (lastHour === \"1 PM\") outgoingShift = \"6 AM - 2 PM\";\nelse if (lastHour === \"2 PM\") outgoingShift = \"7 AM - 3 PM\";\nelse if (lastHour === \"3 PM\") outgoingShift = \"8 AM - 4 PM\";\nelse if (lastHour === \"5 PM\") outgoingShift = \"10 AM - 6 PM\";\n\nconst isCriticalHour = (outgoingShift !== \"\");\n\n// 2. Step Two: Build the dynamic status table (Monospace)\nlet tableText = \"```\\n\"; \ntableText += \"AGENT           | TKS | STATUS\\n\";\ntableText += \"------------------------------\\n\";\n\nagentsProcessed.forEach(ag => {\n  let statusEmoji = \"🔴\"; // Below 80% of average\n  \n  if (ag.tickets >= teamAverage) {\n    statusEmoji = \"🟢\"; // Above average\n  } \n  else if (ag.tickets >= (teamAverage * 0.8)) {\n    statusEmoji = \"🟡\"; // Close to average (80%+)\n  }\n\n  const fixedName = ag.name.substring(0, 15).padEnd(15, ' ');\n  const fixedTickets = ag.tickets.toString().padStart(3, ' ');\n  tableText += `${fixedName} | ${fixedTickets} | ${statusEmoji}\\n`;\n});\n\ntableText += \"------------------------------\\n\";\ntableText += `TOTAL TEAM      | ${teamTotal.toString().padStart(3, ' ')} | 🚀\\n`;\ntableText += \"```\";\n\n// 3. Improved n8n Output Mapping\nconst output = inputItems.map((item, index) => {\n  // We create the summary only for the first item to avoid redundancy\n  const summary = index === 0 ? {\n    table_content: tableText,\n    grand_total: teamTotal,\n    average_productivity: teamAverage.toFixed(1),\n    cutoff_time: lastHour,\n    sla_score: slaResult, // The dynamic value matching Power BI\n    shift_name: outgoingShift,\n    is_critical: isCriticalHour\n  } : null;\n\n  return {\n    json: {\n      // Tickets per agent for the Excel PUT\n      total_val: (index < agentsProcessed.length) ? agentsProcessed[index].tickets : null,\n      \n      // Data for Gemini and Slack nodes\n      slack_message: summary, \n      data_for_ai: summary \n    }\n  };\n});\n\n// Extra item for Grand Total row in Excel\noutput.push({ \n  json: { \n    total_val: teamTotal, \n    is_grand_total: true \n  } \n});\n\nreturn output;"
      },
